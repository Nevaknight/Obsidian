    let sW={y:[],n:[]}, sE={y:[],n:[]}, sH={y:[],n:[]}, sA={y:[],n:[]};
    const specsMap = new Map();
    
    for (let char of rows) {
        const name = char.Имя || char.file.name; const server = char.Сервер || ""; const icon = iconMapping.get(char.Класс) || ""; 
        let items = char[`Предметы: ${pName}`] || []; if(!Array.isArray(items)) items=[items];
        const chk = pre => { const f = items.find(i=>i.toString().startsWith(pre)); return { ex: !!f, epic: f?.toString().includes("Эпическое") }; };
        const w=chk("Оружие:"), h=chk("Шапка:"), a=chk("Фартук:"), e=items.some(i=>i.toString().includes("зачарено"));
        const wrap = (o) => ({ nameHtml: `<span style="color:${o.epic?"#a335ee":"inherit"}; font-weight:${o.epic?"bold":"normal"};">${name}</span>`, rawName: name, server, classIcon: icon });
        
        (w.ex?sW.y:sW.n).push(wrap(w)); (e?sE.y:sE.n).push(wrap({epic:false})); (h.ex?sH.y:sH.n).push(wrap(h)); (a.ex?sA.y:sA.n).push(wrap(a));
        
        let sProp = char[`Специализация: ${pName}`] || []; if(!Array.isArray(sProp)) sProp=[sProp];
        sProp.forEach(s => { const t = s.trim(); if (!specsMap.has(t)) specsMap.set(t, []); specsMap.get(t).push(wrap({epic:false})); });
