// 1. КОНФИГУРАЦИЯ ПУТЕЙ
const registryPath = "Реестр данных/World of Warcraft/Реестр данных - профессии";
const charactersFolder = '"Реестр данных/World of Warcraft/Профессии"';

// 2. ПОЛУЧЕНИЕ ДАННЫХ ИЗ РЕЕСТРА
const registryPage = dv.page(registryPath);
const iconMapping = new Map();
let tokenPrice = 0, goldEarned = 0, goldSpent = 0;
let lastDataMonth = "месяц"; 
const financeHistory = []; // Массив для истории финансов

const monthNamesCase = {
    "01": "январь", "02": "февраль", "03": "март", "04": "апрель",
    "05": "май", "06": "июнь", "07": "июль", "08": "август",
    "09": "сентябрь", "10": "октябрь", "11": "ноябрь", "12": "декабрь"
};

async function getFinanceData() {
    try {
        const file = app.vault.getAbstractFileByPath(registryPath + ".md");
        if (!file) return;
        const content = await app.vault.read(file);
        const rows = content.match(/\|\s*([\d.]+)\s*\|\s*(\d+)\s*\|\s*(\d+)\s*\|/g);
        if (rows && rows.length > 0) {
            // Собираем историю всех записей
            for (let row of rows) {
                const parts = row.split('|').filter(p => p.trim() !== "");
                const dateStr = parts[0].trim();
                const monthNum = dateStr.split('.')[0];
                const yearStr = dateStr.split('.')[1] || "";
                const monthName = monthNamesCase[monthNum] || "месяц";
                const earned = parseInt(parts[1].trim()) || 0;
                const spent = parseInt(parts[2].trim()) || 0;
                
                financeHistory.push({
                    dateStr: dateStr,
                    monthName: monthName,
                    year: yearStr,
                    earned: earned,
                    spent: spent,
                    profit: earned - spent
                });
            }

            // Данные для главных карточек (последняя запись)
            const lastRow = financeHistory[financeHistory.length - 1];
            lastDataMonth = lastRow.monthName;
            goldEarned = lastRow.earned;
            goldSpent = lastRow.spent;
        }
    } catch (e) { console.error("Ошибка финансов:", e); }
}

