    const classes = ["Паладин", "Друид", "Монах", "Маг", "Пробудитель", "Воин", "Охотник на демонов", "Шаман", "Жрец", "Охотник", "Чернокнижник", "Разбойник", "Рыцарь смерти"];
    classes.forEach(c => { if (registryPage[`Иконка: ${c}`]) iconMapping.set(c, registryPage[`Иконка: ${c}`]); });

    const extraIcons = ["Кузнечное дело", "Броня", "Чары", "Хлам", "Инструменты", "Зелья", "Настои", "Алхимия", "Фартук", "Шапка", "Наложение чар", "Масла", "Инженерное дело", "Начертание", "Ювелирное дело", "Портняжное дело", "Флаконы", "Зелье безрассудства", "Трактаты", "Рулоны"];
    extraIcons.forEach(n => { if (registryPage[`Иконка: ${n}`]) iconMapping.set(n, registryPage[`Иконка: ${n}`]); });
    tokenPrice = registryPage["Цена: Жетон World of Warcraft"] || 0;
}

await getFinanceData();

const pages = dv.pages(charactersFolder);
const charDataMap = new Map();
const professionGroups = new Map();
const dandanCharacters = [];

pages.forEach(p => {
    const name = p.Имя || p.file.name;
    const server = p.Сервер || "Сервер";
    const charKey = `${name.trim()}-${server.trim()}`;
    const isMax = p["Максимальный уровень"] === true;
    
    // Сохраняем дополнительные данные для списка Макс. уровня
    if (!charDataMap.has(charKey)) {
        charDataMap.set(charKey, { 
            isMaxLevel: isMax,
            name: name,
            server: server,
            classIcon: iconMapping.get(p.Класс) || ""
        });
    } else if (isMax) {
        charDataMap.get(charKey).isMaxLevel = true;
    }

    let profs = p.Профессия ? (Array.isArray(p.Профессия) ? p.Профессия : [p.Профессия]) : [];
    profs.forEach(prof => {
        const profName = prof.trim();
        if (!professionGroups.has(profName)) professionGroups.set(profName, []);
        professionGroups.get(profName).push(p);
    });

    // Оптимизированная логика "Дандан требуется для" (< 2 эпических оружий)
    let epicWeaponCount = 0;
    for (let key in p) {
        if (key.startsWith("Предметы:")) {
            let items = p[key] ? (Array.isArray(p[key]) ? p[key] : [p[key]]) : [];
            if (items.some(i => i.toString().includes("Оружие:") && i.toString().includes("Эпическое"))) {
                epicWeaponCount++;
            }
        }
    }
    
    // Показываем только тех, у кого МЕНЕЕ 2 эпических оружий
    if (epicWeaponCount < 2) {
        dandanCharacters.push({
            nameHtml: `<span style="color:var(--text-normal); font-weight:bold;">${name}</span>`,
            rawName: name, server: server, classIcon: iconMapping.get(p.Класс) || ""
        });
    }
});

