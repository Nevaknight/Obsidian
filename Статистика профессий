            b.onmouseenter=e=>showTooltip(e,`${label}: ${txt}`,lst); b.onmousemove=e=>{tooltip.style.left=Math.min(e.clientX+15,window.innerWidth-tooltip.offsetWidth-15)+"px";tooltip.style.top=Math.min(e.clientY+15,window.innerHeight-tooltip.offsetHeight-15)+"px";}; b.onmouseleave=()=>{tooltip.style.display="none";}; b.onclick=()=>{tooltip.style.display="none";openListModal(`${pName}: ${label} (${txt})`,lst);}; return b;
        };
        if (noL.length === 0) bCon.appendChild(btn("Собрано", yesL.length, yesL, false)); 
        else if (yesL.length === 0) bCon.appendChild(btn("Нет", noL.length, noL, true)); 
        else { bCon.appendChild(btn("Собрано", yesL.length, yesL, false)); bCon.appendChild(btn("Нет", noL.length, noL, true)); }
        r.appendChild(bCon); card.appendChild(r);
