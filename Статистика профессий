    tooltip.style.display = "block"; tooltip.style.left = Math.min(e.clientX+15, window.innerWidth-tooltip.offsetWidth-15)+"px"; tooltip.style.top = Math.min(e.clientY+15, window.innerHeight-tooltip.offsetHeight-15)+"px";
