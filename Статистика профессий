    addRow("Фартук", "Фартук", "🎽", sA.y, sA.n);

    specsMap.forEach((list, s) => {
        const l = s.toLowerCase(); let iK = iconMapping.has(s) ? s : (l.includes("зель")?"Зелья":l.includes("насто")?"Настои":l.includes("масл")?"Масла":l.includes("брон")?"Броня":l.includes("инжен")||l.includes("инструмент")?"Инструменты":l.includes("налож")||l.includes("чар")?"Наложение чар":l.includes("кузн")||l.includes("оружи")?"Кузнечное дело":l.includes("алхим")?"Алхимия":l.includes("начерт")?"Начертание":l.includes("ювел")?"Ювелирное дело":l.includes("портн")?"Портняжное дело":null);
        const r = document.createElement("div"); r.className = "wow-prof-row";
