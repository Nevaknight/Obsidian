const openListModal = (title, list) => {
    const overlay = document.createElement("div"); overlay.className = "wow-modal-overlay";
    const itemsHtml = list.sort((a,b)=>a.rawName.localeCompare(b.rawName)).map(c => `<div class="wow-list-item"><div class="wow-icon-container">${c.classIcon ? `<img src="${c.classIcon}" style="width:28px;height:28px;border-radius:4px;">` : "👤"}</div><span class="wow-char-name">${c.nameHtml}</span><span class="wow-char-server">${c.server}</span></div>`).join("");
    overlay.innerHTML = `<div class="wow-modal-content"><div class="wow-modal-header"><h3 style="margin:0">${title}</h3><span style="opacity:0.4; font-weight:bold;">${list.length}</span></div><div class="wow-modal-body">${itemsHtml}</div><div style="padding:15px; display:flex; justify-content:center; border-top:1px solid var(--background-modifier-border);"><button class="tool-btn" id="wow-close-modal">Закрыть</button></div></div>`;
    overlay.onclick = (e) => { if (e.target === overlay) overlay.remove(); };
    document.body.appendChild(overlay);
    overlay.querySelector("#wow-close-modal").onclick = () => overlay.remove();
};

const openFinanceModal = (title, type) => {
    const overlay = document.createElement("div"); overlay.className = "wow-modal-overlay";
    const reversedHistory = [...financeHistory].reverse();
    const itemsHtml = reversedHistory.map(item => {
        let val = 0, color = "", icon = "💰";
        if (type === "profit") { val = item.profit; color = "#4caf50"; icon = "📈"; }
        if (type === "earned") { val = item.earned; color = "var(--text-normal)"; icon = "📥"; }
        if (type === "spent") { val = item.spent; color = "#f44336"; icon = "📤"; }
        
        return `<div class="wow-list-item">
            <div class="wow-icon-container"><span style="font-size:24px">${icon}</span></div>
            <span class="wow-char-name">${item.monthName} ${item.year}</span>
            <span class="wow-char-server" style="color:${color}; font-weight:bold; font-size:1.2em; opacity:1;">${formatGold(val)}</span>
        </div>`;
    }).join("");
    overlay.innerHTML = `<div class="wow-modal-content"><div class="wow-modal-header"><h3 style="margin:0">${title}</h3><span style="opacity:0.4; font-weight:bold;">Записей: ${reversedHistory.length}</span></div><div class="wow-modal-body">${itemsHtml}</div><div style="padding:15px; display:flex; justify-content:center; border-top:1px solid var(--background-modifier-border);"><button class="tool-btn" id="wow-close-modal">Закрыть</button></div></div>`;
