        r.innerHTML = `<div style="font-weight:bold; display:flex; align-items:center; flex:1; min-width:0;">${getIconHtml(iconK, fall, 30)}<span style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${label}</span></div>`;
