const openFinanceModal = (title, type) => {
    const overlay = document.createElement("div"); 
    overlay.className = "wow-modal-overlay";
    const reversedHistory = [...financeHistory].reverse();
    let itemsHtml = "";
    for (let item of reversedHistory) {
        let val = 0, color = "", icon = "💰";
