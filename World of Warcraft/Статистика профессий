pages.forEach(p => {
    const name = p.Имя || p.file.name;
    const server = p.Сервер || "Сервер";
    const charKey = name.trim() + "-" + server.trim();
    const isMax = p["Максимальный уровень"] === true;
    
    if (!charDataMap.has(charKey)) {
        charDataMap.set(charKey, { 
            isMaxLevel: isMax,
            name: name,
            server: server,
            classIcon: iconMapping.get(p.Класс) || ""
        });
    } else if (isMax) {
        charDataMap.get(charKey).isMaxLevel = true;
    }

    let profs = p.Профессия ? (Array.isArray(p.Профессия) ? p.Профессия : [p.Профессия]) : [];
    profs.forEach(prof => {
        const profName = prof.trim();
        if (!professionGroups.has(profName)) professionGroups.set(profName, []);
        professionGroups.get(profName).push(p);
    });
});

