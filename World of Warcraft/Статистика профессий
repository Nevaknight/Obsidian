    classes.forEach(c => { if (registryPage["Иконка: " + c]) iconMapping.set(c, registryPage["Иконка: " + c]); });

    const extraIcons = ["Кузнечное дело", "Броня", "Чары", "Хлам", "Инструменты", "Зелья", "Настои", "Алхимия", "Фартук", "Шапка", "Наложение чар", "Масла", "Инженерное дело", "Начертание", "Ювелирное дело", "Портняжное дело", "Флаконы", "Зелье безрассудства", "Трактаты", "Рулоны", "Кожевничество", "Призмы"];
    extraIcons.forEach(n => { if (registryPage["Иконка: " + n]) iconMapping.set(n, registryPage["Иконка: " + n]); });
    tokenPrice = registryPage["Цена: Жетон World of Warcraft"] || 0;
}

