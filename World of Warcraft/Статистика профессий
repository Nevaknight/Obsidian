const showTooltip = (e, title, list) => {
    const limit = 8;
    let listHtml = "";
    const sliced = list.slice(0, limit);
    for (let c of sliced) {
        const iconImg = c.classIcon ? '<img src="' + c.classIcon + '" style="width:24px;height:24px;border-radius:4px;">' : "👤";
