const openListModal = (title, list) => {
    const overlay = document.createElement("div"); 
    overlay.className = "wow-modal-overlay";
    const sortedList = list.sort((a,b) => a.rawName.localeCompare(b.rawName));
    let itemsHtml = "";
    for (let c of sortedList) {
        const iconContent = c.classIcon ? '<img src="' + c.classIcon + '" style="width:28px;height:28px;border-radius:4px;">' : "👤";
        itemsHtml += '<div class="wow-list-item"><div class="wow-icon-container">' + iconContent + '</div><span class="wow-char-name">' + c.nameHtml + '</span><span class="wow-char-server">' + c.server + '</span></div>';
    }
    overlay.innerHTML = '<div class="wow-modal-content"><div class="wow-modal-header"><h3 style="margin:0">' + title + '</h3><span style="opacity:0.4; font-weight:bold;">' + list.length + '</span></div><div class="wow-modal-body">' + itemsHtml + '</div><div style="padding:15px; display:flex; justify-content:center; border-top:1px solid var(--background-modifier-border);"><button class="tool-btn" id="wow-close-modal">Закрыть</button></div></div>';
