const sortedNames = Array.from(professionGroups.keys()).sort((a,b) => { const p = n => (n==="Алхимия"?1:n==="Наложение чар"?2:3); return p(a)!==p(b) ? p(a)-p(b) : a.localeCompare(b,'ru'); });

for (let pName of sortedNames) {
    const rows = professionGroups.get(pName);
    let sW={e:[],r:[],n:[]}, sE={e:[],r:[],n:[]}, sH={e:[],r:[],n:[]}, sA={e:[],r:[],n:[]};
    const specsMap = new Map();
    
    for (let char of rows) {
        const name = char.Имя || char.file.name; 
        const server = char.Сервер || ""; 
        const icon = iconMapping.get(char.Класс) || ""; 
        let items = char["Предметы: " + pName] || []; 
        if(!Array.isArray(items)) items=[items];
        
        const chk = pre => { 
            const f = items.find(i=>i.toString().startsWith(pre)); 
            const isEpic = f ? f.toString().includes("Эпическое") : false;
            return { ex: !!f, epic: isEpic, rare: !!f && !isEpic }; 
        };
        
        const w=chk("Оружие:"), h=chk("Шапка:"), a=chk("Фартук:");
        const eItem = items.find(i=>i.toString().includes("зачарено"));
        const eIsEpic = eItem ? eItem.toString().includes("Эпическое") : false;
        const e = { ex: !!eItem, epic: eIsEpic, rare: !!eItem && !eIsEpic };
        
        const wrap = (o) => ({ 
            nameHtml: '<span style="color:' + (o.epic ? "#a335ee" : (o.rare ? "#0070dd" : "inherit")) + '; font-weight:' + (o.epic || o.rare ? "bold" : "normal") + ';">' + name + '</span>', 
            rawName: name, 
            server: server, 
            classIcon: icon 
        });
        
        if(w.ex) { if(w.epic) sW.e.push(wrap(w)); else sW.r.push(wrap(w)); } else sW.n.push(wrap(w));
        if(e.ex) { if(e.epic) sE.e.push(wrap(e)); else sE.r.push(wrap(e)); } else sE.n.push(wrap(e));
        if(h.ex) { if(h.epic) sH.e.push(wrap(h)); else sH.r.push(wrap(h)); } else sH.n.push(wrap(h));
        if(a.ex) { if(a.epic) sA.e.push(wrap(a)); else sA.r.push(wrap(a)); } else sA.n.push(wrap(a));
        
        let sProp = char["Специализация: " + pName] || []; 
        if(!Array.isArray(sProp)) sProp=[sProp];
        sProp.forEach(s => { 
            const t = s.trim(); 
            if (!specsMap.has(t)) specsMap.set(t, []); 
            specsMap.get(t).push(wrap({epic:false, rare:false})); 
        });
    }

    const card = document.createElement("div"); 
    card.className = "wow-prof-card";
    card.innerHTML = '<div class="wow-prof-header"><h3 style="margin:0; display:flex; align-items:center; justify-content:center;">' + getIconHtml(pName, "📂", 24) + pName + '</h3><div style="font-size:0.85em; opacity:0.7;">Персонажей: <b>' + rows.length + '</b></div></div>';

    const addRow = (iconK, label, fall, epicL, rareL, noL) => {
